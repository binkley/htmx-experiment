{
  "name": "htmx-experiment",
  "version": "0.0.0",
  "description": "Kick the tires on HTMLX",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "npm run build:css && node index.js",
    "test": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":100,\"functions\":100,\"lines\":100,\"statements\":100}}'",
    "validate:push": "npm run format:check && npm run lint && npm run test",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:commit": "lint-staged",
    "build:css": "tailwindcss -i ./styles/input.css -o ./public/styles.css",
    "watch:css": "tailwindcss -i ./styles/input.css -o ./public/styles.css --watch",
    "dev": "npm-run-all --parallel watch:css start"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:binkley/htmx-experiment.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ejs": "^6.0.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.14",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,ejs}": [
      "prettier --write"
    ]
  }
}
