{
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 4,
    "overrides": [
        {
            "files": ["*.json", "*.md", "*.yml", "*.yaml"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["*.ejs"],
            "options": {
                "parser": "html"
            }
        }
    ]
}
