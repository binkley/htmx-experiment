<%
let base = "font-medium rounded transition-colors cursor-pointer";
let variants = {
    primary: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white",
    success: "px-4 py-1.5 bg-green-600 hover:bg-green-700 text-white",
    danger: "px-3 py-1 text-sm text-red-600 border border-red-600 hover:bg-red-50 hover:text-red-700",
    secondary: "px-4 py-1.5 text-gray-700 bg-gray-100 hover:bg-gray-200 border border-gray-300"
};
let btnClass = base + " " + variants[variant] + (locals.className ? " " + className : "");
%>
<!-- prettier-ignore -->
<button type="<%= locals.type || 'button' %>" class="<%= btnClass %>" <%- locals.attributes || '' %>>
    <%= text %>
</button>
