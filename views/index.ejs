<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>HTMX Experiment</title>
        <link rel="stylesheet" href="/styles.css" />
        <script
            src="https://unpkg.com/htmx.org@1.9.10"
            integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7NLX/SoJYkXDFfX37iInKRy5xLSi8nO7UC"
            crossorigin="anonymous"
        ></script>
    </head>
    <body>
        <h1>HTMX Experiment</h1>

        <div class="header-actions">
            <!-- Out-of-Band Target injected by EJS directly on load -->
            <%- include('partials/stats', { todos: todos }) %>

            <div>
                <input
                    type="search"
                    name="q"
                    placeholder="Search tasks..."
                    autocomplete="off"
                    hx-get="/todos"
                    hx-trigger="keyup changed delay:300ms, search"
                    hx-target="#todo-list"
                    hx-indicator="#search-spinner"
                />
                <span id="search-spinner" class="htmx-indicator spinner">⏳ Searching...</span>
            </div>
        </div>

        <form
            hx-post="/todos"
            hx-target="#todo-list"
            hx-swap="beforeend"
            hx-on::after-request="if(event.detail.successful) this.reset()"
        >
            <input type="text" name="title" placeholder="What needs to be done?" required />
            <button type="submit" style="cursor: pointer">Add Todo</button>
        </form>

        <!-- By using EJS, we Server-Side Render the initial state, improving perceived performance -->
        <ul id="todo-list" style="list-style: none; padding: 0; margin: 0">
            <% todos.forEach(function(todo) { %> <%- include('partials/todo', { todo: todo }) %> <%
            }); %>
        </ul>
    </body>
</html>
