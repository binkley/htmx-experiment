<!DOCTYPE html>
<html lang="en" data-theme="cupcake">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>HTMX Experiment</title>
        <link rel="stylesheet" href="/styles.css" />
        <script
            src="https://unpkg.com/htmx.org@1.9.10"
            integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7NLX/SoJYkXDFfX37iInKRy5xLSi8nO7UC"
            crossorigin="anonymous"
        ></script>
        <style>
            .htmx-indicator {
                opacity: 0;
                transition: opacity 200ms ease-in;
            }
            .htmx-request .htmx-indicator {
                opacity: 1;
            }
            .htmx-request.htmx-indicator {
                opacity: 1;
            }
        </style>
    </head>
    <body class="bg-base-200 min-h-screen py-10 px-4">
        <main class="max-w-2xl mx-auto">
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body">
                    <h1 class="card-title text-3xl font-bold mb-6 text-primary">HTMX Experiment</h1>

                    <div
                        class="flex justify-between items-center mb-6 pb-6 border-b border-base-300"
                    >
                        <!-- Out-of-Band Target injected by EJS directly on load -->
                        <%- include('partials/stats', { todos: todos }) %>

                        <div class="flex items-center gap-2">
                            <input
                                type="search"
                                name="q"
                                placeholder="Search tasks..."
                                autocomplete="off"
                                hx-get="/todos"
                                hx-trigger="keyup changed delay:300ms, search"
                                hx-target="#todo-list"
                                hx-indicator="#search-spinner"
                                class="input input-sm input-bordered w-full max-w-xs"
                            />
                            <span
                                id="search-spinner"
                                class="htmx-indicator loading loading-spinner loading-sm text-primary"
                            ></span>
                        </div>
                    </div>

                    <form
                        hx-post="/todos"
                        hx-target="#todo-list"
                        hx-swap="beforeend"
                        hx-on::after-request="if(event.detail.successful) this.reset()"
                        class="flex gap-2 mb-6"
                    >
                        <input
                            type="text"
                            name="title"
                            placeholder="What needs to be done?"
                            required
                            class="input input-bordered grow"
                        />
                        <button type="submit" class="btn btn-primary">Add Todo</button>
                    </form>

                    <!-- By using EJS, we Server-Side Render the initial state, improving perceived performance -->
                    <ul id="todo-list" class="menu bg-base-100 rounded-box p-0">
                        <% todos.forEach(function(todo) { %> <%- include('partials/todo', { todo:
                        todo }) %> <% }); %>
                    </ul>
                </div>
            </div>
        </main>
    </body>
</html>
