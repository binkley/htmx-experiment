<% const isCompleted = todo.completed; %>
<li
    class="flex items-center justify-between py-3 border-b border-gray-200 <%= isCompleted ? 'opacity-75' : '' %>"
    id="todo-<%= todo.id %>"
>
    <label
        class="flex items-center gap-3 grow cursor-pointer <%= isCompleted ? 'line-through text-gray-500' : 'text-gray-800' %>"
    >
        <% if (isCompleted) { %>
        <input
            type="checkbox"
            hx-patch="/todos/<%= todo.id %>/toggle"
            hx-target="#todo-<%= todo.id %>"
            hx-swap="outerHTML"
            checked
            class="w-5 h-5 text-blue-600 rounded border-gray-300 focus:ring-blue-500 cursor-pointer"
        />
        <% } else { %>
        <input
            type="checkbox"
            hx-patch="/todos/<%= todo.id %>/toggle"
            hx-target="#todo-<%= todo.id %>"
            hx-swap="outerHTML"
            class="w-5 h-5 text-blue-600 rounded border-gray-300 focus:ring-blue-500 cursor-pointer"
        />
        <% } %>
        <span
            hx-get="/todos/<%= todo.id %>/edit"
            hx-target="#todo-<%= todo.id %>"
            hx-swap="outerHTML"
            title="Click to edit text"
            class="hover:text-blue-600 transition-colors"
        >
            <%= todo.title %>
        </span>
    </label>
    <%- include('../components/button', { variant: 'danger', className: 'ml-4', text: 'Delete',
    attributes: `hx-delete="/todos/${todo.id}" hx-target="#todo-${todo.id}" hx-swap="outerHTML"` })
    %>
</li>
