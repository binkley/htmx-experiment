<% const isCompleted = todo.completed; %>
<li
    class="hover:bg-base-200 transition-colors rounded-lg mb-1 <%= isCompleted ? 'opacity-75' : '' %>"
    id="todo-<%= todo.id %>"
>
    <div class="flex items-center justify-between w-full p-2">
        <label
            class="flex items-center gap-4 grow cursor-pointer <%= isCompleted ? 'line-through text-base-content/50' : 'text-base-content' %>"
        >
            <% if (isCompleted) { %>
            <input
                type="checkbox"
                hx-patch="/todos/<%= todo.id %>/toggle"
                hx-target="#todo-<%= todo.id %>"
                hx-swap="outerHTML"
                checked
                class="checkbox checkbox-primary"
            />
            <% } else { %>
            <input
                type="checkbox"
                hx-patch="/todos/<%= todo.id %>/toggle"
                hx-target="#todo-<%= todo.id %>"
                hx-swap="outerHTML"
                class="checkbox checkbox-primary"
            />
            <% } %>
            <span
                hx-get="/todos/<%= todo.id %>/edit"
                hx-target="#todo-<%= todo.id %>"
                hx-swap="outerHTML"
                title="Click to edit text"
                class="hover:text-primary transition-colors text-lg"
            >
                <%= todo.title %>
            </span>
        </label>
        <button
            class="btn btn-error btn-sm btn-outline ml-4"
            onclick="document.getElementById('delete-modal-<%= todo.id %>').showModal()"
        >
            Delete
        </button>

        <!-- daisyUI Modal for Delete Confirmation -->
        <dialog id="delete-modal-<%= todo.id %>" class="modal">
            <div class="modal-box">
                <h3 class="font-bold text-lg text-base-content">Confirm Deletion</h3>
                <p class="py-4 text-base-content">
                    Are you sure you want to delete "<strong><%= todo.title %></strong>"? This
                    action cannot be undone.
                </p>
                <div class="modal-action">
                    <form method="dialog">
                        <!-- if there is a button in form, it will close the modal natively -->
                        <button class="btn btn-ghost">Cancel</button>
                    </form>
                    <button
                        hx-delete="/todos/<%= todo.id %>"
                        hx-target="#todo-<%= todo.id %>"
                        hx-swap="outerHTML"
                        class="btn btn-error"
                    >
                        Yes, Delete
                    </button>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop">
                <button>close</button>
            </form>
        </dialog>
    </div>
</li>
